{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["node", "react", "react-dom"],
    "rootDir": "./src",
    "outDir": ".",
    "declaration": false,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["main.js", "main.js.map"]
}
